# ─────────────────────────────────────────────────────
# Bharvishya v2.0 — Environment Configuration
# Copy this to .env and fill in your values
# ─────────────────────────────────────────────────────

# ── REQUIRED ──────────────────────────────────────────
# Get your Gemini API key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ── OPTIONAL: STT Backend ─────────────────────────────
# Set to "true" to use local Whisper (more accurate, offline)
# Default: Google Speech Recognition (free, requires internet)
USE_WHISPER=false
WHISPER_MODEL=base      # Options: tiny, base, small, medium, large

# ── OPTIONAL: TTS Voice ───────────────────────────────
# edge-tts voices: https://learn.microsoft.com/azure/ai-services/speech-service/language-support
TTS_VOICE=en-IN-PrabhatNeural   # Indian English Male
# TTS_VOICE=en-IN-NeerjaNeural  # Indian English Female
# TTS_VOICE=en-US-GuyNeural     # US English Male
TTS_RATE=+5%
TTS_VOLUME=+0%

# ── OPTIONAL: Email ───────────────────────────────────
# Gmail: Enable 2FA → Generate App Password at:
# https://myaccount.google.com/apppasswords
EMAIL_ADDRESS=your_email@gmail.com
EMAIL_APP_PASSWORD=your_16_char_app_password
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=465

# ── OPTIONAL: Web Search (better results) ─────────────
# Get a free key at https://serper.dev (2500 free queries/month)
# Without this key, DuckDuckGo is used as fallback (no key needed)
SERPER_API_KEY=

# ── OPTIONAL: Google Calendar ─────────────────────────
# Path to your Google Calendar service account credentials JSON
# Without this, a local SQLite calendar is used
GOOGLE_CALENDAR_CREDENTIALS=
